# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Security
JWT_SECRET="YOUR_JWT_SECRET"
ENCRYPTION_KEY="YOUR_ENCRYPTION_KEY_32_CHARS"

# Email Configuration (SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="your_email@example.com"
SMTP_PASS="your_password"
SMTP_FROM="R.E.G. EUROPA <noreply@example.com>"

# API Keys - Spain
IDEALISTA_API_KEY=""
IDEALISTA_SECRET=""

# API Keys - Portugal
DADOS_GOV_PT_API_KEY=""

# API Keys - France
ETALAB_API_KEY=""

# API Keys - Germany
GOVDATA_DE_API_KEY=""

# API Keys - Switzerland
SWISS_GEOADMIN_API_KEY=""

# API Keys - Europe Wide
EU_OPEN_DATA_API_KEY=""

# Denmark - Dataforsyningen
DENMARK_BUILDING_API="https://api.dataforsyningen.dk/ogcapi/features/building_inspire/"

# Germany - ALKIS/WFS
GERMANY_ENABLED=true
GERMANY_AAA_MODEL=AFIS-ALKIS-ATKIS
GERMANY_WFS_BAVARIA=https://geoservices.bayern.de/ogc/ogc_alkis/ows
GERMANY_WFS_NRW=https://www.wfs.nrw.de/geobasis/wfs_nw_alkis
GERMANY_WFS_BW=https://www.lgl-bw.de/wfs/alkis

# Spain - Catastro & IGN
SPAIN_ENABLED=true
SPAIN_CATASTRO_SOAP=https://www1.sedecatastro.gob.es/OVCWS/OVCServWeb/OVCServWeb.asmx
SPAIN_CATASTRO_WMS=https://ovc.catastro.meh.es/Cartografia/WMS/ServidorWMS.aspx
SPAIN_CATASTRO_WFS=https://ovc.catastro.meh.es/INSPIRE/wfs.aspx
SPAIN_IGN_WMS=https://www.ign.es/wms-inspire/ign-base
SPAIN_IGN_WFS=https://www.ign.es/wfs-inspire/ign-base
